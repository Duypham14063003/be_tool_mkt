NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://marketing:marketing@postgres:5432/marketing?schema=public
REDIS_HOST=redis
REDIS_PORT=6379
JWT_ACCESS_SECRET=replace-with-at-least-32-characters
JWT_REFRESH_SECRET=replace-with-another-at-least-32-characters
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
# 32 random bytes encoded as base64, e.g. `openssl rand -base64 32`
TOKEN_ENCRYPTION_KEY=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_DEBUG=false
REPORT_STORAGE_PATH=./reports
CORS_ORIGINS=http://localhost:3001
SOCIAL_PROVIDER_MODE=fake
SEED_ADMIN_PASSWORD=Admin123!
SEED_MARKETING_PASSWORD=Marketing123!
